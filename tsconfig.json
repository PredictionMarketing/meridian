{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@meridian/lineage": ["./packages/lineage/src"],
      "@meridian/connectors": ["./packages/connectors/src"],
      "@meridian/router": ["./packages/router/src"],
      "@meridian/compliance": ["./packages/compliance/src"],
      "@meridian/agents": ["./packages/agents/src"],
      "@meridian/dashboard": ["./packages/dashboard/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
